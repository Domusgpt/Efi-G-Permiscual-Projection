# App
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://efi:efi@localhost:5432/efi_g
REDIS_URL=redis://localhost:6379

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET_SOURCE=efi-source-assets
S3_BUCKET_OUTPUT=efi-generated-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Auth and security
AUTH_SECRET=replace_me
JWT_ISSUER=efi-g-local
AUDIT_SIGNING_SECRET=replace_me

# Payments
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=replace_me

# Verification
VERIFICATION_PROVIDER=mock
VERIFICATION_WEBHOOK_SECRET=replace_me

# Model workers
MODEL_QUEUE_NAME=generation-jobs
DEFAULT_MODEL_PROFILE=flux-schnell-local-v0
WORKER_CONCURRENCY=1

# Policy
POLICY_PROFILE=default-sensitive-media-v0
REVIEW_QUEUE_ENABLED=true
